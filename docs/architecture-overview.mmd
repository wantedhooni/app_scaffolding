flowchart TB
  subgraph FE["frontend/ui-admin (Next.js + Refine)"]
    FE_APP["src/app\n- /domain/users, admins, roles, permissions\n- /categories, /blog-posts"]
    FE_PROV["providers\n- auth-provider\n- data-provider\n- http-client"]
